<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- OLED Black — pure black with blue accents -->
    <Color x:Key="CrustColor">#000000</Color>
    <Color x:Key="MantleColor">#050505</Color>
    <Color x:Key="BaseColor">#0A0A0A</Color>
    <Color x:Key="Surface0Color">#141414</Color>
    <Color x:Key="Surface1Color">#1F1F1F</Color>
    <Color x:Key="Surface2Color">#2A2A2A</Color>
    <Color x:Key="OverlayColor">#3D3D3D</Color>
    <Color x:Key="TextColor">#F5F5F5</Color>
    <Color x:Key="SubtextColor">#BEBEBE</Color>
    <Color x:Key="Subtext0Color">#858585</Color>
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="AccentHoverColor">#60A5FA</Color>
    <Color x:Key="GreenColor">#22C55E</Color>
    <Color x:Key="RedColor">#EF4444</Color>
    <Color x:Key="YellowColor">#EAB308</Color>
    <Color x:Key="PeachColor">#F97316</Color>
    <Color x:Key="TealColor">#14B8A6</Color>
    <Color x:Key="MauveColor">#A855F7</Color>
    <SolidColorBrush x:Key="CrustBrush" Color="{StaticResource CrustColor}"/>
    <SolidColorBrush x:Key="MantleBrush" Color="{StaticResource MantleColor}"/>
    <SolidColorBrush x:Key="BaseBrush" Color="{StaticResource BaseColor}"/>
    <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0Color}"/>
    <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1Color}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="OverlayBrush" Color="{StaticResource OverlayColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
    <SolidColorBrush x:Key="Subtext0Brush" Color="{StaticResource Subtext0Color}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}"/>
    <SolidColorBrush x:Key="PeachBrush" Color="{StaticResource PeachColor}"/>
    <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}"/>
    <SolidColorBrush x:Key="MauveBrush" Color="{StaticResource MauveColor}"/>
</ResourceDictionary>
