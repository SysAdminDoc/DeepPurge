<Window x:Class="DeepPurge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeepPurge.App.ViewModels"
        xmlns:conv="clr-namespace:DeepPurge.App.Converters"
        Title="DeepPurge v0.8.0" Width="1380" Height="900"
        MinWidth="1060" MinHeight="700" WindowStartupLocation="CenterScreen"
        Style="{DynamicResource MainWindowStyle}">

    <Window.Resources>
        <FontFamily x:Key="Ico">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StringToVisibilityConverter x:Key="BadgeVisConverter"/>

        <!-- ══ NAV BUTTON ══ -->
        <Style x:Key="NavRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6,1,10,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="indicator" Width="3" HorizontalAlignment="Left" CornerRadius="0,2,2,0"
                                    Background="{DynamicResource AccentBrush}" Opacity="0" Margin="-6,6,0,6"/>
                            <Border x:Name="bg" Padding="12,9,14,9" CornerRadius="8" Background="Transparent">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource Surface0Brush}"/>
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bg" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{DynamicResource TextColor}" Opacity="0.04"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}"/>
            <Setter Property="Margin" Value="18,18,0,6"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>

        <Style x:Key="NavIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource Ico}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Badge pill for nav items -->
        <Style x:Key="NavBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="NavBadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Scan progress bar under nav items -->
        <Style x:Key="NavProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="2"/>
            <Setter Property="Margin" Value="12,2,14,0"/>
            <Setter Property="Background" Value="{DynamicResource Surface0Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="1" ClipToBounds="True">
                            <Grid>
                                <Border x:Name="PART_Track"/>
                                <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                        CornerRadius="1" HorizontalAlignment="Left"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Master Checkbox Header Template -->
        <DataTemplate x:Key="MasterCheckboxHeader">
            <CheckBox x:Name="masterCb" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Click="MasterCheckbox_Click" ToolTip="Select All / None"/>
        </DataTemplate>

        <!-- ══ CONTEXT MENU STYLE ══ -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource MantleBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Surface1Brush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.4" Color="#000000"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource UIFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}" Margin="2,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontFamily="{StaticResource Ico}" FontSize="12"
                                           Foreground="{DynamicResource Subtext0Brush}" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Surface0Brush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource Subtext0Brush}"/>
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuSep" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
            <Setter Property="Background" Value="{DynamicResource Surface0Brush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Background="{TemplateBinding Background}" Height="1" Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon+Name cell template for programs DataGrid -->
        <DataTemplate x:Key="IconNameCell">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{DynamicResource Surface0Color}"/>
                    </Border.Background>
                    <Image Source="{Binding Icon}" Width="20" Height="20"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </DataTemplate>

        <!-- ══ LOADING OVERLAY STORYBOARDS ══ -->
        <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>

        <!-- Spinner rotation -->
        <Storyboard x:Key="SpinnerRotation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotateTransform"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>

    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinnerRotation}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- ROOT GRID -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <Grid Background="{DynamicResource CrustBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SIDEBAR -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource MantleBrush}">
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#06FFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="0.3"/>
                        <GradientStop Color="#03000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <DockPanel>
                    <!-- BRAND -->
                    <Border DockPanel.Dock="Top" Padding="20,22,20,18">
                        <DockPanel>
                            <!-- Theme Toggle (Sun/Moon) -->
                            <Button x:Name="btnThemeToggle" DockPanel.Dock="Right" Click="ThemeToggle_Click"
                                    VerticalAlignment="Center" Cursor="Hand" ToolTip="Toggle Light/Dark"
                                    Width="34" Height="34">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="toggleBg" Background="{DynamicResource Surface0Brush}"
                                                CornerRadius="8" Width="34" Height="34">
                                            <TextBlock x:Name="toggleIcon" Text="&#xE706;" FontFamily="{StaticResource Ico}" FontSize="15"
                                                       Foreground="{DynamicResource SubtextBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="toggleBg" Property="Background" Value="{DynamicResource Surface1Brush}"/>
                                                <Setter TargetName="toggleIcon" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,14,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource MauveColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="14" ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource Ico}" FontSize="17"
                                               Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="DeepPurge" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock FontSize="10.5" Foreground="{DynamicResource Subtext0Brush}" Margin="0,1,0,0">
                                        <Run Text="v0.8.0"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Top" Height="1" Margin="20,0" Background="{DynamicResource Surface0Brush}" Opacity="0.6"/>

                    <!-- FOOTER -->
                    <Border DockPanel.Dock="Bottom" Padding="16,12,16,16">
                        <StackPanel>
                            <Border Height="1" Background="{DynamicResource Surface0Brush}" Opacity="0.6" Margin="0,0,0,12"/>
                            <TextBlock Text="THEME" FontSize="9.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Subtext0Brush}" Margin="4,0,0,6" Opacity="0.5"/>
                            <ComboBox x:Name="cmbTheme" SelectionChanged="Theme_SelectionChanged" FontSize="11.5"/>
                            <Border Background="{DynamicResource Surface0Brush}" CornerRadius="8"
                                    Padding="12,7" Margin="0,10,0,0" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEA37;" FontFamily="{StaticResource Ico}" FontSize="12"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ProgramCountText}" FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- NAV -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,6,0,0">
                        <StackPanel>
                            <TextBlock Text="UNINSTALL" Style="{StaticResource SectionLabel}"/>

                            <!-- Installed Programs + badge -->
                            <RadioButton x:Name="navPrograms" GroupName="nav" IsChecked="True" Checked="NavButton_Checked" Tag="Programs"
                                         Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding ProgramsBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding ProgramsBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74C;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Installed Programs" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>
                            <ProgressBar Value="{Binding ProgramsScanProgress}" Style="{StaticResource NavProgressBar}"/>

                            <RadioButton GroupName="nav" Tag="Forced" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE71C;" Style="{StaticResource NavIcon}"/>
                                    <TextBlock Text="Forced Uninstall" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="WindowsApps" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding WindowsAppsBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding WindowsAppsBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE71D;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Windows Apps" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <TextBlock Text="CLEANUP" Style="{StaticResource SectionLabel}"/>

                            <!-- Junk Cleaner + badge -->
                            <RadioButton GroupName="nav" Tag="Junk" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding JunkBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding JunkBadge}" Style="{StaticResource NavBadgeText}"
                                                   Foreground="{DynamicResource PeachBrush}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE74D;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Junk Cleaner" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>
                            <ProgressBar Value="{Binding JunkScanProgress}" Style="{StaticResource NavProgressBar}"/>

                            <RadioButton GroupName="nav" Tag="Evidence" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding EvidenceBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding EvidenceBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72E;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Evidence Remover" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="EmptyFolders" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding EmptyFoldersBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding EmptyFoldersBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Empty Folders" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="Disk" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEDA2;" Style="{StaticResource NavIcon}"/>
                                    <TextBlock Text="Disk Analyzer" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <TextBlock Text="SYSTEM" Style="{StaticResource SectionLabel}"/>

                            <RadioButton GroupName="nav" Tag="Autorun" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding AutorunBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding AutorunBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Autorun Manager" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="BrowserExt" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding BrowserExtBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding BrowserExtBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE774;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Browser Extensions" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="ContextMenu" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding ContextMenuBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding ContextMenuBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE762;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Context Menu" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton GroupName="nav" Tag="Services" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding ServicesBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding ServicesBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE912;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Services" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <!-- Scheduled Tasks + badge -->
                            <RadioButton GroupName="nav" Tag="Tasks" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource NavBadge}"
                                            Visibility="{Binding TasksBadge, Converter={StaticResource BadgeVisConverter}}">
                                        <TextBlock Text="{Binding TasksBadge}" Style="{StaticResource NavBadgeText}"/>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE823;" Style="{StaticResource NavIcon}"/>
                                        <TextBlock Text="Scheduled Tasks" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>
                            <ProgressBar Value="{Binding TasksScanProgress}" Style="{StaticResource NavProgressBar}"/>

                            <RadioButton GroupName="nav" Tag="Hunter" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" Style="{StaticResource NavIcon}"/>
                                    <TextBlock Text="Registry Hunter" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <TextBlock Text="SAFETY" Style="{StaticResource SectionLabel}"/>
                            <RadioButton GroupName="nav" Tag="Restore" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE777;" Style="{StaticResource NavIcon}"/>
                                    <TextBlock Text="Restore Points" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton GroupName="nav" Tag="Backups" Checked="NavButton_Checked" Style="{StaticResource NavRadioButton}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE7B8;" Style="{StaticResource NavIcon}"/>
                                    <TextBlock Text="Registry Backups" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- Sidebar edge shadow -->
        <Border Grid.Column="1" HorizontalAlignment="Left" Width="16" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#18000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── TOOLBAR: PROGRAMS ── -->
            <Border Grid.Row="0" x:Name="toolbarMain" Padding="20,14,20,14">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Background="{DynamicResource BaseBrush}"
                            CornerRadius="10" Width="300"
                            BorderBrush="{DynamicResource Surface0Brush}" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="&#xE721;" FontFamily="{StaticResource Ico}" FontSize="13"
                                       Foreground="{DynamicResource Subtext0Brush}" Opacity="0.5"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0"
                                       IsHitTestVisible="False"/>
                            <TextBox x:Name="txtSearch" Background="Transparent" BorderThickness="0"
                                     Padding="34,9,12,9" TextChanged="SearchBox_TextChanged" FontSize="12.5"/>
                        </Grid>
                    </Border>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Background="{DynamicResource BaseBrush}" CornerRadius="10" Padding="14,0"
                                Margin="0,0,10,0" VerticalAlignment="Center" Height="36"
                                BorderBrush="{DynamicResource Surface0Brush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#xE7B8;" FontFamily="{StaticResource Ico}" FontSize="12"
                                           Foreground="{DynamicResource Subtext0Brush}" Margin="0,0,8,0"
                                           VerticalAlignment="Center" Opacity="0.6"/>
                                <RadioButton x:Name="rbSafe" Content="Safe" GroupName="scanMode"
                                             Foreground="{DynamicResource GreenBrush}" Margin="0,0,8,0"
                                             VerticalAlignment="Center" FontSize="11"/>
                                <RadioButton x:Name="rbModerate" Content="Moderate" GroupName="scanMode" IsChecked="True"
                                             Foreground="{DynamicResource YellowBrush}" Margin="0,0,8,0"
                                             VerticalAlignment="Center" FontSize="11"/>
                                <RadioButton x:Name="rbAdvanced" Content="Advanced" GroupName="scanMode"
                                             Foreground="{DynamicResource PeachBrush}"
                                             VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Button x:Name="btnExport" Content="Export" Click="Export_Click" Style="{DynamicResource GhostButton}" Margin="0,0,5,0"/>
                        <Button x:Name="btnRefresh" Content="Refresh" Click="Refresh_Click" Style="{DynamicResource GhostButton}" Margin="0,0,5,0"/>
                        <Button x:Name="btnScanLeftovers" Content="Scan Leftovers" Click="ScanLeftovers_Click" Margin="0,0,5,0"/>
                        <Button x:Name="btnUninstall" Content="Uninstall" Click="Uninstall_Click" Style="{DynamicResource AccentButton}" Margin="0,0,5,0"/>
                        <Button x:Name="btnBulkUninstall" Content="Uninstall Selected" Click="BulkUninstall_Click"
                                Style="{DynamicResource DangerButton}" Margin="0,0,5,0"
                                ToolTip="Uninstall every program with a checkbox. Silent flags applied automatically."/>
                        <Button x:Name="btnDeleteLeftovers" Content="Delete Selected" Click="DeleteLeftovers_Click"
                                Style="{DynamicResource DangerButton}" IsEnabled="False"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── TOOLBAR: GENERIC ── -->
            <Border Grid.Row="0" x:Name="toolbarGeneric" Padding="24,14,20,14" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock x:Name="txtPanelTitle" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                    <StackPanel x:Name="genericButtons" DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>

            <!-- ── CONTENT CARD ── -->
            <Border Grid.Row="1" Margin="16,2,16,0" CornerRadius="14,14,0,0" ClipToBounds="True"
                    Background="{DynamicResource BaseBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.2" Color="#000000" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <!-- Subtle top gradient -->
                    <Border Height="60" VerticalAlignment="Top" IsHitTestVisible="False" CornerRadius="14,14,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#08FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- PROGRAMS -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgPrograms"
                              ItemsSource="{Binding FilteredPrograms}"
                              SelectionChanged="Programs_SelectionChanged"
                              MouseDoubleClick="Programs_DoubleClick">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Uninstall" Tag="&#xE74D;" Click="Uninstall_Click"/>
                                <MenuItem Header="Uninstall Selected (bulk)" Tag="&#xE74D;" Click="BulkUninstall_Click"/>
                                <MenuItem Header="Scan Leftovers" Tag="&#xE721;" Click="ScanLeftovers_Click"/>
                                <MenuItem Header="Upgrade via winget" Tag="&#xE777;" Click="Ctx_WingetUpgrade_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Open Install Folder" Tag="&#xE838;" Click="Ctx_OpenFolder_Click"/>
                                <MenuItem Header="Open in Registry" Tag="&#xE756;" Click="Ctx_OpenRegistry_Click"/>
                                <MenuItem Header="Copy Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                                <MenuItem Header="Invert Selection" Tag="&#xE7C1;" Click="Ctx_InvertSelection_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTemplateColumn Header="PROGRAM" Width="*" MinWidth="260"
                                                    CellTemplate="{StaticResource IconNameCell}" SortMemberPath="DisplayName"/>
                            <DataGridTextColumn Binding="{Binding Publisher}" Header="PUBLISHER" Width="180"/>
                            <DataGridTextColumn Binding="{Binding DisplayVersion}" Header="VERSION" Width="105"/>
                            <DataGridTextColumn Binding="{Binding EstimatedSizeDisplay}" Header="SIZE" Width="90"/>
                            <DataGridTextColumn Binding="{Binding InstallDateDisplay}" Header="INSTALLED" Width="105"/>
                            <DataGridTextColumn Binding="{Binding SourceDisplay}" Header="SOURCE" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- FORCED UNINSTALL -->
                    <Border x:Name="panelForced" Visibility="Collapsed">
                        <Border Padding="60,48" MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel>
                                <Border Width="52" Height="52" CornerRadius="14" Margin="0,0,0,24" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{DynamicResource PeachColor}" Offset="0"/>
                                            <GradientStop Color="{DynamicResource RedColor}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="{DynamicResource RedColor}" BlurRadius="18" ShadowDepth="0" Opacity="0.25"/>
                                    </Border.Effect>
                                    <TextBlock Text="&#xE71C;" FontFamily="{StaticResource Ico}" FontSize="22" Foreground="#FFFFFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Forced Uninstall" FontSize="24" FontWeight="Bold" Margin="0,0,0,8"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}"
                                           Margin="0,0,0,32" FontSize="13" LineHeight="21">
                                    Scan for remnants of programs that were partially removed or don't appear in the installed programs list.
                                </TextBlock>
                                <TextBlock Text="PROGRAM NAME" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Subtext0Brush}" Margin="2,0,0,8" Opacity="0.6"/>
                                <TextBox x:Name="txtForcedName" Margin="0,0,0,22"/>
                                <TextBlock Text="INSTALL FOLDER  (optional)" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Subtext0Brush}" Margin="2,0,0,8" Opacity="0.6"/>
                                <DockPanel Margin="0,0,0,32">
                                    <Button DockPanel.Dock="Right" Content="Browse" Click="BrowseFolder_Click" Margin="10,0,0,0" Padding="20,9"/>
                                    <TextBox x:Name="txtForcedPath"/>
                                </DockPanel>
                                <Button Content="Run Forced Scan" Style="{DynamicResource AccentButton}"
                                        Click="ForcedScan_Click" HorizontalAlignment="Left" Padding="32,11" FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!-- WINDOWS APPS -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgWindowsApps" Visibility="Collapsed" ItemsSource="{Binding WindowsApps}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove App" Tag="&#xE74D;" Click="RemoveWindowsApp_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Copy App Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding DisplayName}" Header="APP NAME" Width="*" MinWidth="240"/>
                            <DataGridTextColumn Binding="{Binding Publisher}" Header="PUBLISHER" Width="180"/>
                            <DataGridTextColumn Binding="{Binding Version}" Header="VERSION" Width="115"/>
                            <DataGridTextColumn Binding="{Binding SizeDisplay}" Header="SIZE" Width="90"/>
                            <DataGridTextColumn Binding="{Binding Architecture}" Header="ARCH" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- JUNK CLEANER (pre-loaded) -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgJunk" Visibility="Collapsed" ItemsSource="{Binding JunkCategories}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Clean Selected" Tag="&#xE74D;" Click="CleanJunk_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanJunk_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="CATEGORY" Width="220"/>
                            <DataGridTextColumn Binding="{Binding Description}" Header="DESCRIPTION" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Files.Count}" Header="ITEMS" Width="75"/>
                            <DataGridTextColumn Binding="{Binding TotalSizeDisplay}" Header="SIZE" Width="105"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- EVIDENCE -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgEvidence" Visibility="Collapsed" ItemsSource="{Binding TraceCategories}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Clean Selected" Tag="&#xE74D;" Click="CleanEvidence_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanEvidence_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="CATEGORY" Width="240"/>
                            <DataGridTextColumn Binding="{Binding Description}" Header="DESCRIPTION" Width="*"/>
                            <DataGridTextColumn Binding="{Binding ItemCount}" Header="ITEMS" Width="75"/>
                            <DataGridTextColumn Binding="{Binding TotalSizeDisplay}" Header="SIZE" Width="105"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- EMPTY FOLDERS -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgEmptyFolders" Visibility="Collapsed" ItemsSource="{Binding EmptyFolders}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Delete Selected" Tag="&#xE74D;" Click="DeleteEmptyFolders_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Open in Explorer" Tag="&#xE838;" Click="Ctx_OpenFolderPath_Click"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanEmptyFolders_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Path}" Header="FOLDER PATH" Width="*"/>
                            <DataGridTextColumn Binding="{Binding ParentFolder}" Header="PARENT" Width="240"/>
                            <DataGridTextColumn Binding="{Binding LastModifiedDisplay}" Header="MODIFIED" Width="135"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- DISK -->
                    <Grid x:Name="panelDisk" Visibility="Collapsed">
                        <TabControl>
                            <TabItem Header="Folder Sizes">
                                <DataGrid AutoGenerateColumns="False" x:Name="dgFolderSizes" ItemsSource="{Binding DiskFolders}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Name}" Header="FOLDER" Width="*"/>
                                        <DataGridTextColumn Binding="{Binding SizeDisplay}" Header="SIZE" Width="115"/>
                                        <DataGridTextColumn Binding="{Binding FileCount}" Header="FILES" Width="85"/>
                                        <DataGridTextColumn Binding="{Binding FolderCount}" Header="FOLDERS" Width="85"/>
                                        <DataGridTextColumn Binding="{Binding PercentageDisplay}" Header="%" Width="75"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Large Files">
                                <DataGrid AutoGenerateColumns="False" x:Name="dgLargeFiles" ItemsSource="{Binding LargeFiles}">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                                HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                                        <DataGridTextColumn Binding="{Binding Name}" Header="FILE" Width="280"/>
                                        <DataGridTextColumn Binding="{Binding Path}" Header="PATH" Width="*"/>
                                        <DataGridTextColumn Binding="{Binding Extension}" Header="TYPE" Width="75"/>
                                        <DataGridTextColumn Binding="{Binding SizeDisplay}" Header="SIZE" Width="115"/>
                                        <DataGridTextColumn Binding="{Binding LastModifiedDisplay}" Header="MODIFIED" Width="105"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>

                    <!-- AUTORUN -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgAutorun" Visibility="Collapsed" ItemsSource="{Binding Autoruns}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Toggle Enable/Disable" Tag="&#xE7B3;" Click="Ctx_ToggleAutorun_Click"/>
                                <MenuItem Header="Delete Entry" Tag="&#xE74D;" Click="DeleteAutorun_Click" Foreground="{DynamicResource RedBrush}"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Open File Location" Tag="&#xE838;" Click="Ctx_OpenAutorunPath_Click"/>
                                <MenuItem Header="Copy Command" Tag="&#xE8C8;" Click="Ctx_CopyCommand_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsEnabled}" Header="ON" Width="54"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="NAME" Width="200"/>
                            <DataGridTextColumn Binding="{Binding Location}" Header="LOCATION" Width="150"/>
                            <DataGridTextColumn Binding="{Binding Command}" Header="COMMAND" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Publisher}" Header="PUBLISHER" Width="130"/>
                            <DataGridTextColumn Binding="{Binding SignatureDisplay}" Header="SIGNATURE" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- BROWSER EXT -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgBrowserExt" Visibility="Collapsed" ItemsSource="{Binding BrowserExtensions}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove Extension" Tag="&#xE74D;" Click="RemoveBrowserExt_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Open Extension Folder" Tag="&#xE838;" Click="Ctx_OpenExtFolder_Click"/>
                                <MenuItem Header="Copy Extension Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Header="EXTENSION" Width="*" MinWidth="220"/>
                            <DataGridTextColumn Binding="{Binding Browser}" Header="BROWSER" Width="140"/>
                            <DataGridTextColumn Binding="{Binding ProfileName}" Header="PROFILE" Width="110"/>
                            <DataGridTextColumn Binding="{Binding Version}" Header="VERSION" Width="105"/>
                            <DataGridTextColumn Binding="{Binding SizeDisplay}" Header="SIZE" Width="85"/>
                            <DataGridTextColumn Binding="{Binding IsEnabled}" Header="ON" Width="58"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- CONTEXT MENU -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgContextMenu" Visibility="Collapsed" ItemsSource="{Binding ContextMenuEntries}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove Orphaned" Tag="&#xE74D;" Click="RemoveContextMenu_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanContextMenu_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                                <MenuItem Header="Copy Entry Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="ENTRY" Width="240"/>
                            <DataGridTextColumn Binding="{Binding Location}" Header="LOCATION" Width="180"/>
                            <DataGridTextColumn Binding="{Binding Command}" Header="COMMAND" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Status}" Header="STATUS" Width="95"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- SERVICES -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgServices" Visibility="Collapsed" ItemsSource="{Binding Services}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Disable Service" Tag="&#xE769;" Click="DisableService_Click"/>
                                <MenuItem Header="Delete Service" Tag="&#xE74D;" Click="DeleteService_Click" Foreground="{DynamicResource RedBrush}"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Open in services.msc" Tag="&#xE912;" Click="Ctx_OpenServicesMsc_Click"/>
                                <MenuItem Header="Copy Service Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanServices_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding DisplayName}" Header="SERVICE" Width="*" MinWidth="200"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="NAME" Width="170"/>
                            <DataGridTextColumn Binding="{Binding StartType}" Header="STARTUP" Width="90"/>
                            <DataGridTextColumn Binding="{Binding StatusDisplay}" Header="STATUS" Width="90"/>
                            <DataGridTextColumn Binding="{Binding SignatureDisplay}" Header="SIGNATURE" Width="130"/>
                            <DataGridTextColumn Binding="{Binding ImagePath}" Header="PATH" Width="210"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- TASKS (pre-loaded) -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgTasks" Visibility="Collapsed" ItemsSource="{Binding ScheduledTasks}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Delete Task" Tag="&#xE74D;" Click="DeleteTask_Click" Foreground="{DynamicResource RedBrush}"/>
                                <MenuItem Header="Open Task Scheduler" Tag="&#xE823;" Click="Ctx_OpenTaskScheduler_Click"/>
                                <MenuItem Header="Copy Task Name" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                                <MenuItem Header="Rescan" Tag="&#xE72C;" Click="ScanTasks_Click"/>
                                <Separator Style="{StaticResource MenuSep}"/>
                                <MenuItem Header="Check All" Tag="&#xE73A;" Click="Ctx_CheckAll_Click"/>
                                <MenuItem Header="Uncheck All" Tag="&#xE739;" Click="Ctx_UncheckAll_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Name}" Header="TASK" Width="260"/>
                            <DataGridTextColumn Binding="{Binding Author}" Header="AUTHOR" Width="160"/>
                            <DataGridTextColumn Binding="{Binding Action}" Header="ACTION" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Status}" Header="STATUS" Width="95"/>
                            <DataGridTextColumn Binding="{Binding LastRunTime}" Header="LAST RUN" Width="135"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- RESTORE -->
                    <DataGrid AutoGenerateColumns="False" x:Name="dgRestore" Visibility="Collapsed" ItemsSource="{Binding RestorePoints}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Create New Restore Point" Tag="&#xE710;" Click="CreateRestorePoint_Click"/>
                                <MenuItem Header="Copy Description" Tag="&#xE8C8;" Click="Ctx_CopyName_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                            <DataGridTextColumn Binding="{Binding Description}" Header="DESCRIPTION" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Type}" Header="TYPE" Width="170"/>
                            <DataGridTextColumn Binding="{Binding CreationTimeDisplay}" Header="CREATED" Width="150"/>
                            <DataGridTextColumn Binding="{Binding AgeDisplay}" Header="AGE" Width="95"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- REGISTRY HUNTER -->
                    <Grid x:Name="panelHunter" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="24,16,24,16">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Search" Click="RegistryHunt_Click"
                                        Style="{DynamicResource AccentButton}" Margin="10,0,0,0" Padding="22,8"/>
                                <TextBox x:Name="txtHunter" KeyDown="HunterInput_KeyDown"
                                         ToolTip="Search all of HKLM / HKCU / HKCR for a substring (3+ chars)"/>
                            </DockPanel>
                        </Border>
                        <DataGrid Grid.Row="1" x:Name="dgHunter" AutoGenerateColumns="False"
                                  ItemsSource="{Binding RegistryHits}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Path}" Header="PATH" Width="*"/>
                                <DataGridTextColumn Binding="{Binding ValueName}" Header="VALUE" Width="180"/>
                                <DataGridTextColumn Binding="{Binding ValueData}" Header="DATA" Width="300"/>
                                <DataGridTextColumn Binding="{Binding Match}" Header="MATCH" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- BACKUPS -->
                    <Border x:Name="panelBackups" Visibility="Collapsed" Padding="48,32">
                        <StackPanel MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <TextBlock Text="Registry Backups" FontSize="24" FontWeight="Bold"
                                       Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SubtextBrush}"
                                       Margin="0,0,0,24" FontSize="13" LineHeight="21">
                                Every destructive registry operation creates a <Run FontWeight="SemiBold">.reg</Run> export
                                in your local app data. Open the folder to inspect, import, or prune backups.
                            </TextBlock>
                            <Button Content="Open Backup Folder" Click="OpenBackupFolder_Click"
                                    Style="{DynamicResource AccentButton}" HorizontalAlignment="Left" Padding="28,10"/>
                        </StackPanel>
                    </Border>

                    <!-- LEFTOVER RESULTS OVERLAY -->
                    <Border x:Name="panelLeftovers" Visibility="Collapsed" Background="{DynamicResource BaseBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Padding="24,16" Background="{DynamicResource MantleBrush}" CornerRadius="14,14,0,0">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Back" Click="BackToPrograms_Click"
                                            Style="{DynamicResource GhostButton}" Padding="20,8"/>
                                    <StackPanel>
                                        <TextBlock x:Name="txtLeftoverTitle" Text="{Binding LeftoverTitle}" FontSize="17" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock x:Name="txtLeftoverInfo" Text="{Binding LeftoverInfo}" FontSize="11.5"
                                                   Foreground="{DynamicResource SubtextBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <TabControl Grid.Row="1">
                                <TabItem Header="Registry Leftovers">
                                    <DataGrid AutoGenerateColumns="False" x:Name="dgRegistryLeftovers" ItemsSource="{Binding RegistryLeftovers}">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                                            <DataGridTextColumn Binding="{Binding DisplayPath}" Header="REGISTRY PATH" Width="*"/>
                                            <DataGridTextColumn Binding="{Binding Details}" Header="DETAILS" Width="260"/>
                                            <DataGridTextColumn Binding="{Binding Confidence}" Header="SAFETY" Width="85"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                                <TabItem Header="File Leftovers">
                                    <DataGrid AutoGenerateColumns="False" x:Name="dgFileLeftovers" ItemsSource="{Binding FileLeftovers}">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="44"
                                                                    HeaderTemplate="{StaticResource MasterCheckboxHeader}"/>
                                            <DataGridTextColumn Binding="{Binding DisplayPath}" Header="PATH" Width="*"/>
                                            <DataGridTextColumn Binding="{Binding SizeDisplay}" Header="SIZE" Width="95"/>
                                            <DataGridTextColumn Binding="{Binding Details}" Header="DETAILS" Width="220"/>
                                            <DataGridTextColumn Binding="{Binding Confidence}" Header="SAFETY" Width="85"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                            <Border Grid.Row="2" Padding="20,12" Background="{DynamicResource MantleBrush}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Content="Select Safe" Click="SelectAllSafe_Click" Margin="0,0,6,0"/>
                                        <Button Content="Deselect All" Click="DeselectAll_Click" Margin="0,0,12,0"/>
                                        <Button Content="Delete Selected" Click="DeleteLeftovers_Click"
                                                Style="{DynamicResource DangerButton}"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtLeftoverStats" Text="{Binding LeftoverStats}" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SubtextBrush}" FontSize="12"/>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- STATUS BAR -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Padding="22,7,22,9"
                    BorderBrush="{DynamicResource Surface0Brush}" BorderThickness="0,0.5,0,0">
                <DockPanel>
                    <ProgressBar x:Name="progressBar" Width="160" Height="3" DockPanel.Dock="Right"
                                 Margin="16,0,0,0" VerticalAlignment="Center"
                                 Value="{Binding OperationProgress}"
                                 Visibility="{Binding OperationProgressVisible, Converter={StaticResource BoolToVis}}"/>
                    <ProgressBar x:Name="busyBar" Width="160" Height="3" DockPanel.Dock="Right"
                                 Margin="16,0,0,0" VerticalAlignment="Center" IsIndeterminate="True">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsBusy}" Value="True"/>
                                            <Condition Binding="{Binding OperationProgressVisible}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- Dry-run + secure-delete toggles (BleachBit/PrivaZer pattern) -->
                    <Border DockPanel.Dock="Right" CornerRadius="6" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center" Background="{DynamicResource Surface0Brush}">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="chkDryRun" IsChecked="{Binding DryRunEnabled}"
                                      VerticalAlignment="Center" ToolTip="Preview: enumerate and size items without deleting">
                                <TextBlock Text="Dry Run" FontSize="10.5" FontWeight="Medium"
                                           Foreground="{DynamicResource YellowBrush}" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </CheckBox>
                            <CheckBox x:Name="chkSecure" IsChecked="{Binding SecureDeleteEnabled}"
                                      VerticalAlignment="Center" Margin="14,0,0,0"
                                      ToolTip="Overwrite file contents before unlink. Slower; no recycle-bin recovery.">
                                <TextBlock Text="Secure Delete" FontSize="10.5" FontWeight="Medium"
                                           Foreground="{DynamicResource RedBrush}" VerticalAlignment="Center"
                                           Margin="6,0,0,0"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <!-- Live progress text when an operation is running -->
                    <Border DockPanel.Dock="Right" CornerRadius="6" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center" Background="{DynamicResource Surface0Brush}"
                            Visibility="{Binding OperationProgressVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding OperationProgressText}" FontSize="10.5" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="380"/>
                    </Border>

                    <!-- Junk total badge -->
                    <Border DockPanel.Dock="Right" CornerRadius="6" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center" Background="{DynamicResource Surface0Brush}">
                        <TextBlock Text="{Binding TotalJunkDisplay}" FontSize="10.5" FontWeight="Medium"
                                   Foreground="{DynamicResource PeachBrush}" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Selected count badge -->
                    <Border DockPanel.Dock="Right" CornerRadius="6" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center" Background="{DynamicResource Surface0Brush}"
                            Visibility="{Binding SelectedCountBadge, Converter={StaticResource BadgeVisConverter}}">
                        <TextBlock Text="{Binding SelectedCountBadge}" FontSize="10.5" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="txtStatus" Text="{Binding StatusText}" Foreground="{DynamicResource Subtext0Brush}"
                               FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Opacity="0.7"/>
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- TOAST NOTIFICATION -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border x:Name="toastPanel" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,16,24,0" Padding="16,10,20,10" CornerRadius="10" Opacity="0"
                    IsHitTestVisible="False" Panel.ZIndex="999"
                    Background="{DynamicResource MantleBrush}"
                    BorderBrush="{DynamicResource Surface1Brush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.35" Color="#000000"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="toastIcon" Text="&#xE73E;" FontFamily="{StaticResource Ico}" FontSize="14"
                               Foreground="{DynamicResource GreenBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="toastText" Text="" FontSize="12" FontWeight="Medium"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" MaxWidth="400"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- LOADING OVERLAY (spans entire window) -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border x:Name="LoadingOverlay" Grid.ColumnSpan="2" Visibility="Visible" Opacity="1">
            <Border.Background>
                <SolidColorBrush Color="{DynamicResource CrustColor}" Opacity="0.92"/>
            </Border.Background>
            <Grid>
                <!-- Subtle gradient vignette -->
                <Border IsHitTestVisible="False">
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.45" RadiusX="0.55" RadiusY="0.7">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#12000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Logo icon with glow -->
                    <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,32">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="{DynamicResource AccentColor}" Offset="0"/>
                                <GradientStop Color="{DynamicResource MauveColor}" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="40" ShadowDepth="0" Opacity="0.35"/>
                        </Border.Effect>
                        <TextBlock Text="&#xE74D;" FontFamily="{StaticResource Ico}" FontSize="30" Foreground="#FFFFFF"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- App name -->
                    <TextBlock Text="DeepPurge" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="v0.8.0" FontSize="11" FontWeight="Medium"
                               Foreground="{DynamicResource Subtext0Brush}" HorizontalAlignment="Center" Margin="0,0,0,28"
                               Opacity="0.5"/>

                    <!-- Status text -->
                    <TextBlock Text="{Binding ScanOverlayText}" FontSize="14" FontWeight="Medium"
                               Foreground="{DynamicResource SubtextBrush}" HorizontalAlignment="Center" Margin="0,0,0,18"/>

                    <!-- Animated spinner ring -->
                    <Canvas Width="56" Height="56" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Ellipse Width="56" Height="56" Stroke="{DynamicResource Surface1Brush}" StrokeThickness="2.5" Fill="Transparent"/>
                        <Path Data="M28,0 A28,28 0 0 1 56,28" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" RenderTransformOrigin="0.5,0.5">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotateTransform" Angle="0" CenterX="28" CenterY="28"/>
                            </Path.RenderTransform>
                        </Path>
                    </Canvas>

                    <!-- Subtle progress bar -->
                    <ProgressBar Width="280" Height="2" IsIndeterminate="True"
                                 Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource Surface0Brush}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
